SECRET_KEY=change-this-to-a-random-secret-key

# Session pooler 권장 (Windows/회사망). Dashboard → Database → Connection string → URI → Session pooler
# pooler 호스트는 aws-0 또는 aws-1 — Dashboard에 표시된 값을 그대로 사용 (예: aws-1-ap-northeast-2)
# Direct(db.xxx.supabase.co)는 IPv6만 제공되어 Windows에서 실패할 수 있음
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres

# 회사 VPN/방화벽 TLS 오류 시 (개발·내부망 한정)
# SUPABASE_SSL_VERIFY=0

UPLOAD_DIR=./uploads
RECEIPT_DIR=./receipts
STAMP_DIR=./assets

# SMTP 설정 (미설정 시 콘솔 출력)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@company.com
SMTP_USE_TLS=true
