SECRET_KEY=change-this-to-a-random-secret-key
# Replit 기본 secret 이름 SESSION_SECRET 도 동일하게 인식됩니다.

# Session pooler 권장 (Windows/회사망). Dashboard → Database → Connection string → URI → Session pooler
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres

# Supabase Storage (첨부·날인본 — 로컬·Replit 공통 필수)
# Dashboard → Settings → API → Project URL (선택, DATABASE_URL에서 자동 추론 가능)
# SUPABASE_URL=https://[project-ref].supabase.co
# Dashboard → Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 회사 VPN/방화벽 TLS 오류 시 (DB·Storage 공통, 개발·내부망 한정)
# SUPABASE_SSL_VERIFY=0

# STORAGE_BUCKET=document-attachments

# SMTP 설정 (미설정 시 콘솔 출력)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@company.com
SMTP_USE_TLS=true
