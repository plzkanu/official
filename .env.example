# Replit Secrets / 로컬 backend/.env 공통 (GitHub에 올리지 않음)

SECRET_KEY=your-random-secret-here

# Supabase PostgreSQL Session pooler URI (필수)
# Dashboard → Database → Connection string → URI → Session pooler
# pooler 호스트(aws-0/aws-1)는 Dashboard 값을 그대로 사용
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres

# SUPABASE_SSL_VERIFY=0

STATIC_DIR=../frontend/dist

# SMTP (선택)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@company.com
